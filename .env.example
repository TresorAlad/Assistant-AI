# ============================================
# AI Personal Assistant - Configuration
# ============================================
# Copier ce fichier en .env et remplir les valeurs

# --- IA gratuite (recommande : Groq) ---
# Cle gratuite : https://console.groq.com/keys
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Economie de quota
LLM_DAILY_BUDGET=80
LLM_MIN_INTERVAL_SECONDS=12
LLM_MAX_TOKENS=280
LLM_MAX_HISTORY=6
OWNER_NAME=Tresor

# Ollama local (gratuit, illimite) — https://ollama.com
# OLLAMA_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2:1b

# --- Gemini (secours optionnel) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite
TRANSCRIPTION_MODEL=gemini-2.0-flash-lite

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_URL=http://localhost:8085
EVOLUTION_API_KEY=your-evolution-api-key
WHATSAPP_INSTANCE=assistant
PHONE_NUMBER=22800000000
OWNER_PHONE=22800000000

# --- OpenAI (resumes email planifies) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Planification ---
SCHEDULE_MODE=interval
SCHEDULE_INTERVAL_MINUTES=30
SCHEDULE_MORNING_TIME=08:00
SCHEDULE_EVENING_TIME=20:00

# --- Gmail ---
MAX_EMAILS=10
GMAIL_LABELS=INBOX

# --- Serveur webhook ---
PORT=8000
