# ============================================
# AI Personal Assistant - Configuration
# ============================================
# Copier ce fichier en .env et remplir les valeurs

# --- Gemini (agent WhatsApp + transcription vocale) ---
GEMINI_API_KEY=your-gemini-api-key
TRANSCRIPTION_MODEL=gemini-2.5-flash

# --- Green API (WhatsApp) ---
GREEN_API_URL=https://7107.api.greenapi.com
ID_INSTANCE=your-instance-id
API_TOKEN_INSTANCE=your-api-token
PHONE_NUMBER=22800000000
OWNER_PHONE=22800000000

# --- OpenAI (résumés email planifiés) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Planification ---
# Modes: interval, daily_morning, daily_evening, custom
SCHEDULE_MODE=interval
SCHEDULE_INTERVAL_MINUTES=30
SCHEDULE_MORNING_TIME=08:00
SCHEDULE_EVENING_TIME=20:00

# --- Gmail ---
MAX_EMAILS=10
GMAIL_LABELS=INBOX

# --- Serveur webhook ---
PORT=8000
